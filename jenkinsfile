pipeline {
agent any

environment {
    AWS_REGION = 'eu-north-1'
    AWS_ACCOUNT_ID = '718307299153'
    ECR_REPO_NAME = 'ecommerce-backend'
    ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    IMAGE_TAG = "${BUILD_NUMBER}"
    PREVIOUS_TAG = "${BUILD_NUMBER - 1}"
}

stages {

    stage('Checkout') {
        steps {
            git branch: 'main',
            url: 'https://github.com/dhanushaws47-droid/aws-devops-ecommerce-project.git'
        }
    }

    stage('Build') {
        steps {
            sh 'cd backend && npm install'
        }
    }

    stage('Test') {
        steps {
            sh 'cd backend && echo "No tests yet"'
        }
    }

    stage('Docker Build') {
        steps {
            sh '''
            docker build -t ecommerce-backend ./backend
            '''
        }
    }

    stage('Login to ECR') {
        steps {
            sh '''
            aws ecr get-login-password --region $AWS_REGION | \
            docker login --username AWS --password-stdin $ECR_REGISTRY
            '''
        }
    }

    stage('Push to ECR') {
        steps {
            sh '''
            docker tag ecommerce-backend:latest $ECR_REGISTRY/$ECR_REPO_NAME:$IMAGE_TAG
            docker push $ECR_REGISTRY/$ECR_REPO_NAME:$IMAGE_TAG
            '''
        }
    }

    stage('Deploy') {
        steps {
            echo "Deploy step (ECS coming next phase)"
        }
    }
}

post {
    failure {
        echo "Build failed! Starting rollback..."

        sh '''
        echo "Attempting rollback to previous image: $PREVIOUS_TAG"

        docker pull $ECR_REGISTRY/$ECR_REPO_NAME:$PREVIOUS_TAG || true

        echo "Rollback image ready: $PREVIOUS_TAG"
        '''
    }
}
```

}
